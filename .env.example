# ============================================
# ArtRef Finder 환경변수 템플릿
# .env.local에 복사하여 실제 값을 입력하세요
# ============================================

# bkend.ai 설정 (필수)
# 콘솔 > 프로젝트 설정 > API 키에서 Publishable Key 복사
NEXT_PUBLIC_BKEND_API_URL=https://api-client.bkend.ai/v1
NEXT_PUBLIC_BKEND_API_KEY=pk_your-publishable-key

# 이미지 API (선택)
NEXT_PUBLIC_PEXELS_API_KEY=your-pexels-api-key

# 토스페이먼츠 결제 (구독 결제 사용 시 필수)
# https://developers.tosspayments.com 에서 테스트 키 발급
TOSS_SECRET_KEY=test_sk_...
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
